  "title": "FAQ 1",
  "content": "<!-- wp:group {\"align\":\"full\",\"className\":\"hostinger-ai-faq-1 hostinger-ai-fade-up\",\"layout\":{\"type\":\"constrained\"}} -->\n<div class=\"wp-block-group alignfull hostinger-ai-faq-1 hostinger-ai-fade-up\"><!-- wp:group {\"align\":\"wide\",\"className\":\"hostinger-ai-fade-up\",\"style\":{\"spacing\":{\"padding\":{\"top\":\"var:preset|spacing|60\",\"bottom\":\"var:preset|spacing|60\"}}},\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-group alignwide hostinger-ai-fade-up\" style=\"padding-top:var(--wp--preset--spacing--60);padding-bottom:var(--wp--preset--spacing--60)\"><!-- wp:columns {\"style\":{\"spacing\":{\"margin\":{\"bottom\":\"0\"}}}} -->\n<div class=\"wp-block-columns\" style=\"margin-bottom:0\"><!-- wp:column {\"width\":\"33.33%\"} -->\n<div class=\"wp-block-column\" style=\"flex-basis:33.33%\"><!-- wp:heading {\"className\":\"hostinger-ai-title\",\"style\":{\"elements\":{\"link\":{\"color\":{\"text\":\"var:preset|color|dark\"}}},\"spacing\":{\"margin\":{\"bottom\":\"var:preset|spacing|20\"}}},\"textColor\":\"dark\",\"fontSize\":\"x-large\"} -->\n<h2 class=\"wp-block-heading hostinger-ai-title has-dark-color has-text-color has-link-color has-x-large-font-size\" style=\"margin-bottom:var(--wp--preset--spacing--20)\">FAQs</h2>\n<!-- /wp:heading --></div>\n<!-- /wp:column -->\n\n<!-- wp:column {\"width\":\"66.66%\"} -->\n<div class=\"wp-block-column\" style=\"flex-basis:66.66%\"><!-- wp:group {\"metadata\":{\"name\":\"FAQ Item 1\"},\"className\":\"hostinger-ai-fade-up\",\"style\":{\"spacing\":{\"margin\":{\"bottom\":\"var:preset|spacing|50\"}}},\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-group hostinger-ai-fade-up\" style=\"margin-bottom:var(--wp--preset--spacing--50)\"><!-- wp:paragraph {\"className\":\"hostinger-ai-question hostinger-index-0 hostinger-ai-font-bold\",\"style\":{\"spacing\":{\"margin\":{\"top\":\"0\",\"bottom\":\"var:preset|spacing|20\"}},\"elements\":{\"link\":{\"color\":{\"text\":\"var:preset|color|dark\"}}}},\"textColor\":\"dark\",\"fontSize\":\"medium\"} -->\n<p class=\"hostinger-ai-question hostinger-index-0 hostinger-ai-font-bold has-dark-color has-text-color has-link-color has-medium-font-size\" style=\"margin-top:0;margin-bottom:var(--wp--preset--spacing--20)\"><strong>What services do you offer?</strong></p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph {\"className\":\"hostinger-ai-answer hostinger-index-0\",\"style\":{\"spacing\":{\"margin\":{\"top\":\"0\"}}}} -->\n<p class=\"hostinger-ai-answer hostinger-index-0\" style=\"margin-top:0\">I provide quick interior design fixes and consultations to make your home cozy.</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"metadata\":{\"name\":\"FAQ Item 2\"},\"className\":\"hostinger-ai-fade-up\",\"style\":{\"spacing\":{\"margin\":{\"bottom\":\"var:preset|spacing|50\"}}},\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-group hostinger-ai-fade-up\" style=\"margin-bottom:var(--wp--preset--spacing--50)\"><!-- wp:paragraph {\"className\":\"hostinger-ai-question hostinger-index-1 hostinger-ai-font-bold\",\"style\":{\"spacing\":{\"margin\":{\"top\":\"0\",\"bottom\":\"var:preset|spacing|20\"}},\"elements\":{\"link\":{\"color\":{\"text\":\"var:preset|color|dark\"}}}},\"textColor\":\"dark\",\"fontSize\":\"medium\"} -->\n<p class=\"hostinger-ai-question hostinger-index-1 hostinger-ai-font-bold has-dark-color has-text-color has-link-color has-medium-font-size\" style=\"margin-top:0;margin-bottom:var(--wp--preset--spacing--20)\"><strong>How long is a consultation?</strong></p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph {\"className\":\"hostinger-ai-answer hostinger-index-1\",\"style\":{\"spacing\":{\"margin\":{\"top\":\"0\"}}}} -->\n<p class=\"hostinger-ai-answer hostinger-index-1\" style=\"margin-top:0\">You can easily book your first consultation online through the booking section on this site.</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"metadata\":{\"name\":\"FAQ Item 3\"},\"className\":\"hostinger-ai-fade-up\",\"style\":{\"spacing\":{\"margin\":{\"bottom\":\"var:preset|spacing|50\"}}},\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-group hostinger-ai-fade-up\" style=\"margin-bottom:var(--wp--preset--spacing--50)\"><!-- wp:paragraph {\"className\":\"hostinger-ai-question hostinger-index-2 hostinger-ai-font-bold\",\"style\":{\"spacing\":{\"margin\":{\"top\":\"0\",\"bottom\":\"var:preset|spacing|20\"}},\"elements\":{\"link\":{\"color\":{\"text\":\"var:preset|color|dark\"}}}},\"textColor\":\"dark\",\"fontSize\":\"medium\"} -->\n<p class=\"hostinger-ai-question hostinger-index-2 hostinger-ai-font-bold has-dark-color has-text-color has-link-color has-medium-font-size\" style=\"margin-top:0;margin-bottom:var(--wp--preset--spacing--20)\"><strong>Do you offer virtual consultations?</strong></p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph {\"className\":\"hostinger-ai-answer hostinger-index-2\",\"style\":{\"spacing\":{\"margin\":{\"top\":\"0\"}}}} -->\n<p class=\"hostinger-ai-answer hostinger-index-2\" style=\"margin-top:0\">Absolutely! I specialize in affordable solutions that bring big impact without breaking the bank.</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"metadata\":{\"name\":\"FAQ Item 4\"},\"className\":\"hostinger-ai-fade-up\",\"style\":{\"spacing\":{\"margin\":{\"bottom\":\"var:preset|spacing|50\"}}},\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-group hostinger-ai-fade-up\" style=\"margin-bottom:var(--wp--preset--spacing--50)\"><!-- wp:paragraph {\"className\":\"hostinger-ai-question hostinger-index-3 hostinger-ai-font-bold\",\"style\":{\"spacing\":{\"margin\":{\"top\":\"0\",\"bottom\":\"var:preset|spacing|20\"}},\"elements\":{\"link\":{\"color\":{\"text\":\"var:preset|color|dark\"}}}},\"textColor\":\"dark\",\"fontSize\":\"medium\"} -->\n<p class=\"hostinger-ai-question hostinger-index-3 hostinger-ai-font-bold has-dark-color has-text-color has-link-color has-medium-font-size\" style=\"margin-top:0;margin-bottom:var(--wp--preset--spacing--20)\"><strong>How do I book a consultation?</strong></p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph {\"className\":\"hostinger-ai-answer hostinger-index-3\",\"style\":{\"spacing\":{\"margin\":{\"top\":\"0\"}}}} -->\n<p class=\"hostinger-ai-answer hostinger-index-3\" style=\"margin-top:0\">Yes, virtual consultations are available for your convenience and safety.</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"metadata\":{\"name\":\"FAQ Item 5\"},\"className\":\"hostinger-ai-fade-up\",\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-group hostinger-ai-fade-up\"><!-- wp:paragraph {\"className\":\"hostinger-ai-question hostinger-index-4 hostinger-ai-font-bold\",\"style\":{\"spacing\":{\"margin\":{\"top\":\"0\",\"bottom\":\"var:preset|spacing|20\"}},\"elements\":{\"link\":{\"color\":{\"text\":\"var:preset|color|dark\"}}}},\"textColor\":\"dark\",\"fontSize\":\"medium\"} -->\n<p class=\"hostinger-ai-question hostinger-index-4 hostinger-ai-font-bold has-dark-color has-text-color has-link-color has-medium-font-size\" style=\"margin-top:0;margin-bottom:var(--wp--preset--spacing--20)\"><strong>Can you work with small budgets?</strong></p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph {\"className\":\"hostinger-ai-answer hostinger-index-4\",\"style\":{\"spacing\":{\"margin\":{\"top\":\"0\"}}}} -->\n<p class=\"hostinger-ai-answer hostinger-index-4\" style=\"margin-top:0\">Consultations usually last about one hour, focused on practical tips.</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group --></div>\n<!-- /wp:column --></div>\n<!-- /wp:columns --></div>\n<!-- /wp:group --></div>\n<!-- /wp:group -->",
  "syncStatus": "unsynced"
}