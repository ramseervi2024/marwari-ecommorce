{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "hostinger-ai-theme/map-block",
    "version": "1.0.0",
    "title": "Map",
    "category": "embed",
    "icon": "location-alt",
    "description": "Embeds a Google Maps iframe with an editor preview.",
    "supports": {
        "html": false,
        "anchor": true,
        "align": ["wide", "full"],
        "customClassName": true
    },
    "attributes": {
        "src": {
            "type": "string",
            "default": ""
        },
        "height": {
            "type": "number",
            "default": 450
        }
    },
    "textdomain": "hostinger-ai-theme",
    "editorScript": "file:./build/index.js",
    "render": "file:./render.php"
}
