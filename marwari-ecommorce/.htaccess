RewriteEngine On
RewriteBase /

# Serve superpanel.html for /superpanel requests
RewriteRule ^superpanel$ superpanel.html [L]
RewriteRule ^superpanel/$ superpanel.html [L]

# Serve customer-management.html for /customer-management requests
RewriteRule ^customer-management$ customer-management.html [L]
RewriteRule ^customer-management/$ customer-management.html [L]

# SPA storefront fallback routing
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . index.html [L]
